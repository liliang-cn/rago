# AgentGo Configuration Example
# Place this file in your project root or ~/.agentgo/agentgo.toml

# AgentGo Home directory - unified path for all data, skills, and intents
# Defaults to the directory containing this file if not set
# home = "~/.agentgo"

[llm]
enabled = true
strategy = "round_robin" # round_robin, random, least_load, capability, failover

# LLM Providers - supports OpenAI-compatible APIs (OpenAI, Claude, MiniMax, Ollama, etc.)
[[llm.providers]]
name = "minimax"                    # Provider name (for identification)
base_url = "https://api.minimax.chat/v1"  # API endpoint
key = "your-api-key-here"           # API Key
model_name = "MiniMax-M2.5"         # Model name
max_concurrency = 5                 # Maximum concurrent requests
capability = 4                      # Capability level (1-5)

# Example: Ollama
# [[llm.providers]]
# name = "ollama"
# base_url = "http://localhost:11434/v1"
# key = ""
# model_name = "qwen3.5:8b"

# Example: OpenAI-compatible
# [[llm.providers]]
# name = "openai-compatible"
# base_url = "https://api.example.com/v1"
# key = "sk-..."
# model_name = "gpt-4o-mini"

[embedding]
enabled = true
strategy = "round_robin"

# Embedding Providers
[[embedding.providers]]
name = "qwen3-embedding"
base_url = "http://localhost:11434/v1"
key = ""
model_name = "qwen3-embedding:8b"
max_concurrency = 10
capability = 4

[rag]
top_k = 5                       # Number of relevant chunks to retrieve
threshold = 0.5                 # Similarity threshold (0.0 to 1.0)
index_type = "flat"             # Vector index type: hnsw, ivf, or flat

[chunker]
chunk_size = 500                # Number of characters per chunk
overlap = 50                    # Overlap between chunks
method = "sentence"             # Chunking method: sentence, paragraph, or token

[mcp]
enabled = true                  # Enable Model Context Protocol (MCP) tools
log_level = "info"
default_timeout = "5m"
max_concurrent_requests = 10
health_check_interval = "60s"

[tooling]
saving_mode = false             # Default: send tool definitions directly to the model
enable_search_tools = true      # When saving_mode=true, allow tool search instead of full schemas

[tooling.web_search]
mode = "auto"                   # auto | native | mcp | off
search_context_size = "medium"  # low | medium | high when native/auto search is used

# Built-in servers (filesystem + websearch) are always available — no external
# binaries or mcpServers.json entries needed. They run in-process inside the binary.
#
# filesystem_dirs controls which directories the built-in filesystem server can access.
# Defaults to the user's home directory if not set.
# filesystem_dirs = ["/Users/yourname", "/tmp"]

# Note: Additional servers can be configured in mcpServers.json (auto-discovered in AgentGo home dir)
